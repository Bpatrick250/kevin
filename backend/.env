# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/rlg_database
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/rlg_database

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key

# Admin
ADMIN_EMAIL=admin@rlg.org
ADMIN_PASSWORD=Admin@123456

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=raisingleaderofgeneration@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=raisingleaderofgeneration@gmail.com

# Mobile Money (MTN/Airtel)
MOMO_API_KEY=your_momo_api_key
MOMO_API_SECRET=your_momo_api_secret
MOMO_SUBSCRIPTION_KEY=your_subscription_key
MOMO_ENVIRONMENT=sandbox

# Frontend URL
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_PROD=https://rlg.org

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info